# Shared defaults used by both test and manual compose overlays.

# Fixture bootstrap source
DP_REPO_BRANCH=https://github.com/drupal/recommended-project/tree/11.x

# Deployment runtime user/group
APACHE_RUN_USER=www
APACHE_RUN_GROUP=www

# Database configuration
DB_HOST=mysql
DB_PORT=3306
DB_USER=drupal
DB_PASSWORD=drupal_password
DB_NAME=drupaldb
DB_DRIVER=mysql

# Composer install behavior
COMPOSER_INSTALL_FLAGS=--ignore-platform-req=php

# S3 database import
S3_BUCKET=test-deployments
S3_DATABASE_PATH=test-db.sql.gz
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_REGION=us-east-1

# File proxy configuration
ORIGIN_URL=http://origin-server:8000
FILE_PROXY_PATHS=/sites/default/files
USE_STAGE_FILE_PROXY=no
WEB_ROOT=/var/www/html/web
